{
  "name": "@polity/pulse-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "HACKATHON-ONLY (Red Hat Live Data track). NOT part of the shipped Polity product. A standalone Claw-Agent heartbeat dashboard that watches live civic + GDELT feeds. Never linked from apps/web. See docs/operations/handoff-red-hat-live-data-hackathon-2026-07-18.md.",
  "scripts": {
    "typecheck": "tsc --noEmit && pnpm --dir web typecheck",
    "test": "vitest run --passWithNoTests",
    "web:dev": "pnpm --dir web dev",
    "web:build": "pnpm --dir web build",
    "dev": "pnpm web:build && wrangler dev",
    "deploy": "pnpm web:build && wrangler deploy"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241112.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.86.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  }
}
